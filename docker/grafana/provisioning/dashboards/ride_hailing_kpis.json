          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "success": { "color": "green", "text": "SUCCESS", "index": 0 } } },
                  { "type": "value", "options": { "failed": { "color": "red", "text": "FAILED", "index": 1 } } }
