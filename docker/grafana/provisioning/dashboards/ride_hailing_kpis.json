        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(started_at, 'YYYY-MM-DD HH24:MI') AS \"Started\", pipeline_name AS \"Pipeline\", stage_name AS \"Stage\", status, to_char(ended_at, 'YYYY-MM-DD HH24:MI') AS \"Ended\", ROUND(CAST(details->>'duration_seconds' AS numeric), 2) AS \"Duration (s)\" FROM metadata.pipeline_run_audit ORDER BY started_at DESC LIMIT 20",
          "refId": "A"
        }
