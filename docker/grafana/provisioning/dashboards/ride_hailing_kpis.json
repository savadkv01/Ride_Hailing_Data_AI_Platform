          { "matcher": { "id": "byName", "options": "Risk Band" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "high": { "color": "red", "text": "HIGH", "index": 0 } } }, { "type": "value", "options": { "medium": { "color": "yellow", "text": "MEDIUM", "index": 1 } } }, { "type": "value", "options": { "low": { "color": "green", "text": "LOW", "index": 2 } } }] }] }
