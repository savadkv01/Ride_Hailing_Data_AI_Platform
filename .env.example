# Core database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ride_warehouse
POSTGRES_USER=ride_admin
POSTGRES_PASSWORD=ride_password

# Alternate PG* names supported by scripts/APIs
PGHOST=localhost
PGPORT=5432
PGDATABASE=ride_warehouse
PGUSER=ride_admin
PGPASSWORD=ride_password

# Mongo
MONGO_ROOT_USERNAME=ride_mongo_admin
MONGO_ROOT_PASSWORD=ride_mongo_password
MONGO_URI=mongodb://ride_mongo_admin:ride_mongo_password@localhost:27017

# Kafka
KAFKA_BOOTSTRAP=localhost:9094
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Vector + LLM endpoints
WEAVIATE_URL=http://localhost:8080
WEAVIATE_CLASS=RideDocument
OLLAMA_URL=http://localhost:11434

# API/runtime
APP_ENV=local
MODEL_ARTIFACTS_DIR=ml/artifacts
LOG_LEVEL=INFO
RIDE_API_URL=http://localhost:8000
STREAMLIT_PORT=8501

# Optional: point scripts to specific env file
# ENV_FILE=docker/compose/.env.local
